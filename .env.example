# ============================================================
# NHSO Connect Kiosk — ตัวอย่าง Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# ห้ามใส่รหัสผ่านหรือ token จริงในไฟล์นี้
# ============================================================

# ========== Admin Config Page ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Database HOSxP
HOSXP_DB_URL=mysql+pymysql://DB_USER:DB_PASS@DB_HOST:3306/hospink

# NHSO API
NHSO_MODE=TEST
NHSO_PRD_URL=https://nhsoapi.nhso.go.th/nhsoendpoint/api/nhso-claim-detail
NHSO_TEST_URL=https://test.nhso.go.th/nhsoendpoint/api/nhso-claim-detail
HOSPITAL_CODE=
SOURCE_ID=
NHSO_TOKEN=
RECORDER_PID=

# Kiosk
KIOSK_MODE=true
CARD_READER_MOCK=false
CARD_READER_NAME=
KIOSK_AUTO_RESET_SEC=8
KIOSK_HOSPITAL_NAME=
KIOSK_HOSPITAL_PHONE=
